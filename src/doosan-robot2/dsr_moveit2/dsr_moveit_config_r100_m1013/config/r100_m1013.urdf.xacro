<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="r100_m1013">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />
    <xacro:arg name="color" default="white" />
    <xacro:arg name="arm_prefix" default="arm_" />
    <xacro:arg name="mount_xyz" default="0 0 0" />
    <xacro:arg name="mount_rpy" default="0 0 0" />
    <xacro:arg name="use_gazebo" default="false" />
    <xacro:arg name="host" default="" />
    <xacro:arg name="port" default="" />
    <xacro:arg name="rt_host" default="" />
    <xacro:arg name="mode" default="" />
    <xacro:arg name="model" default="m1013" />
    <xacro:arg name="update_rate" default="" />
    
    <!-- MoveIt whole-body base joints with finite bounds -->
    <link name="odom"/>
    <link name="base_x_link"/>
    <link name="base_xy_link"/>
    <link name="base_yaw_link"/>

    <joint name="base_x" type="prismatic">
      <parent link="odom"/>
      <child link="base_x_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-5.0" upper="5.0" effort="1000.0" velocity="1.0"/>
    </joint>

    <joint name="base_y" type="prismatic">
      <parent link="base_x_link"/>
      <child link="base_xy_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-5.0" upper="5.0" effort="1000.0" velocity="1.0"/>
    </joint>

    <joint name="base_yaw" type="revolute">
      <parent link="base_xy_link"/>
      <child link="base_yaw_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.141592653589793" upper="3.141592653589793" effort="1000.0" velocity="1.0"/>
    </joint>

    <joint name="base_yaw_to_base_link" type="fixed">
      <parent link="base_yaw_link"/>
      <child link="base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Include canonical model xacro (it self-instantiates at file end). -->
    <xacro:include filename="$(find dsr_description2)/xacro/r100_m1013.urdf.xacro" />
</robot>
