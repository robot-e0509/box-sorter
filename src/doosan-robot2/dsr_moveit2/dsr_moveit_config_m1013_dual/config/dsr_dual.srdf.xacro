<?xml version="1.0"?>
<robot name="m1013_dual_mobile" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:arg name="gripper" default="none"/>
  <xacro:property name="grip" value="${xacro.arg('gripper')}"/>

  <!-- Left Arm Planning Group -->
  <group name="left_arm">
    <chain base_link="left_base_link" tip_link="left_link_6" />
  </group>

  <!-- Right Arm Planning Group -->
  <group name="right_arm">
    <chain base_link="right_base_link" tip_link="right_link_6" />
  </group>

  <!-- Dual Arms Planning Group (for coordinated motion) -->
  <group name="dual_arms">
    <group name="left_arm" />
    <group name="right_arm" />
  </group>

  <!-- Mobile Base Group (if needed for navigation) -->
  <group name="mobile_base">
    <joint name="world_to_mobile_base" />
    <joint name="mobile_base_footprint_joint" />
  </group>

  <xacro:if value="${grip == 'robotiq_2f85'}">
    <group name="left_arm_gripper_closed">
      <chain base_link="left_base_link" tip_link="left_gripper_tcp_closed"/>
    </group>
    <group name="left_arm_gripper_opened">
      <chain base_link="left_base_link" tip_link="left_gripper_tcp_opened"/>
    </group>
    <group name="right_arm_gripper_closed">
      <chain base_link="right_base_link" tip_link="right_gripper_tcp_closed"/>
    </group>
    <group name="right_arm_gripper_opened">
      <chain base_link="right_base_link" tip_link="right_gripper_tcp_opened"/>
    </group>
  </xacro:if>

  <!-- Named poses for left arm -->
  <group_state name="left_home" group="left_arm">
    <joint name="left_joint_1" value="0"/>
    <joint name="left_joint_2" value="-0.785"/>  <!-- -45 deg: lift arm -->
    <joint name="left_joint_3" value="1.57"/>    <!-- 90 deg: bend elbow -->
    <joint name="left_joint_4" value="0"/>
    <joint name="left_joint_5" value="0.785"/>   <!-- 45 deg: wrist up -->
    <joint name="left_joint_6" value="0"/>
  </group_state>

  <!-- Named poses for right arm -->
  <group_state name="right_home" group="right_arm">
    <joint name="right_joint_1" value="0"/>
    <joint name="right_joint_2" value="-0.785"/> <!-- -45 deg: lift arm -->
    <joint name="right_joint_3" value="1.57"/>   <!-- 90 deg: bend elbow -->
    <joint name="right_joint_4" value="0"/>
    <joint name="right_joint_5" value="0.785"/>  <!-- 45 deg: wrist up -->
    <joint name="right_joint_6" value="0"/>
  </group_state>

  <!-- Named pose for both arms -->
  <group_state name="dual_home" group="dual_arms">
    <joint name="left_joint_1" value="0"/>
    <joint name="left_joint_2" value="-0.785"/>
    <joint name="left_joint_3" value="1.57"/>
    <joint name="left_joint_4" value="0"/>
    <joint name="left_joint_5" value="0.785"/>
    <joint name="left_joint_6" value="0"/>
    <joint name="right_joint_1" value="0"/>
    <joint name="right_joint_2" value="-0.785"/>
    <joint name="right_joint_3" value="1.57"/>
    <joint name="right_joint_4" value="0"/>
    <joint name="right_joint_5" value="0.785"/>
    <joint name="right_joint_6" value="0"/>
  </group_state>

  <!-- Virtual joint for world frame -->
  <virtual_joint name="world_joint" type="fixed" parent_frame="world" child_link="mobile_base_footprint"/>

  <!-- Collision avoidance - Left arm self-collision -->
  <disable_collisions link1="left_base_link" link2="left_link_1" reason="Adjacent"/>
  <disable_collisions link1="left_base_link" link2="left_link_3" reason="Never"/>
  <disable_collisions link1="left_link_1" link2="left_link_2" reason="Adjacent"/>
  <disable_collisions link1="left_link_1" link2="left_link_3" reason="Never"/>
  <disable_collisions link1="left_link_1" link2="left_link_5" reason="Never"/>
  <disable_collisions link1="left_link_1" link2="left_link_6" reason="Never"/>
  <disable_collisions link1="left_link_2" link2="left_link_3" reason="Adjacent"/>
  <disable_collisions link1="left_link_2" link2="left_link_4" reason="Never"/>
  <disable_collisions link1="left_link_2" link2="left_link_5" reason="Never"/>
  <disable_collisions link1="left_link_2" link2="left_link_6" reason="Never"/>
  <disable_collisions link1="left_link_3" link2="left_link_4" reason="Adjacent"/>
  <disable_collisions link1="left_link_3" link2="left_link_5" reason="Never"/>
  <disable_collisions link1="left_link_3" link2="left_link_6" reason="Never"/>
  <disable_collisions link1="left_link_4" link2="left_link_5" reason="Adjacent"/>
  <disable_collisions link1="left_link_4" link2="left_link_6" reason="Never"/>
  <disable_collisions link1="left_link_5" link2="left_link_6" reason="Adjacent"/>

  <!-- Collision avoidance - Right arm self-collision -->
  <disable_collisions link1="right_base_link" link2="right_link_1" reason="Adjacent"/>
  <disable_collisions link1="right_base_link" link2="right_link_3" reason="Never"/>
  <disable_collisions link1="right_link_1" link2="right_link_2" reason="Adjacent"/>
  <disable_collisions link1="right_link_1" link2="right_link_3" reason="Never"/>
  <disable_collisions link1="right_link_1" link2="right_link_5" reason="Never"/>
  <disable_collisions link1="right_link_1" link2="right_link_6" reason="Never"/>
  <disable_collisions link1="right_link_2" link2="right_link_3" reason="Adjacent"/>
  <disable_collisions link1="right_link_2" link2="right_link_4" reason="Never"/>
  <disable_collisions link1="right_link_2" link2="right_link_5" reason="Never"/>
  <disable_collisions link1="right_link_2" link2="right_link_6" reason="Never"/>
  <disable_collisions link1="right_link_3" link2="right_link_4" reason="Adjacent"/>
  <disable_collisions link1="right_link_3" link2="right_link_5" reason="Never"/>
  <disable_collisions link1="right_link_3" link2="right_link_6" reason="Never"/>
  <disable_collisions link1="right_link_4" link2="right_link_5" reason="Adjacent"/>
  <disable_collisions link1="right_link_4" link2="right_link_6" reason="Never"/>
  <disable_collisions link1="right_link_5" link2="right_link_6" reason="Adjacent"/>

  <!-- Collision avoidance - Mobile base with arms -->
  <disable_collisions link1="mobile_base_link" link2="torso_link" reason="Adjacent"/>
  <disable_collisions link1="mobile_base_link" link2="left_shoulder" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="right_shoulder" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="left_base_link" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="right_base_link" reason="Never"/>
  <disable_collisions link1="torso_link" link2="left_shoulder" reason="Adjacent"/>
  <disable_collisions link1="torso_link" link2="right_shoulder" reason="Adjacent"/>
  <disable_collisions link1="left_shoulder" link2="left_base_link" reason="Adjacent"/>
  <disable_collisions link1="right_shoulder" link2="right_base_link" reason="Adjacent"/>

  <!-- Collision avoidance - Torso with arm links -->
  <disable_collisions link1="torso_link" link2="left_base_link" reason="Never"/>
  <disable_collisions link1="torso_link" link2="left_link_1" reason="Never"/>
  <disable_collisions link1="torso_link" link2="left_link_2" reason="Never"/>
  <disable_collisions link1="torso_link" link2="left_link_3" reason="Never"/>
  <disable_collisions link1="torso_link" link2="right_base_link" reason="Never"/>
  <disable_collisions link1="torso_link" link2="right_link_1" reason="Never"/>
  <disable_collisions link1="torso_link" link2="right_link_2" reason="Never"/>
  <disable_collisions link1="torso_link" link2="right_link_3" reason="Never"/>

  <!-- Collision avoidance - Mobile base with arm links -->
  <disable_collisions link1="mobile_base_link" link2="left_link_1" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="left_link_2" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="left_link_3" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="left_link_4" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="right_link_1" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="right_link_2" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="right_link_3" reason="Never"/>
  <disable_collisions link1="mobile_base_link" link2="right_link_4" reason="Never"/>

  <!-- Collision avoidance - Between two arms (they might collide if too close) -->
  <!-- Allow collision checking between arms for safety, but disable some that never collide -->
  <disable_collisions link1="left_base_link" link2="right_base_link" reason="Never"/>
  <disable_collisions link1="left_shoulder" link2="right_shoulder" reason="Never"/>
  <disable_collisions link1="left_base_link" link2="right_link_1" reason="Never"/>
  <disable_collisions link1="left_base_link" link2="right_link_2" reason="Never"/>
  <disable_collisions link1="right_base_link" link2="left_link_1" reason="Never"/>
  <disable_collisions link1="right_base_link" link2="left_link_2" reason="Never"/>
  <disable_collisions link1="left_link_1" link2="right_link_1" reason="Never"/>
  <disable_collisions link1="left_link_1" link2="right_link_2" reason="Never"/>
  <disable_collisions link1="left_link_2" link2="right_link_1" reason="Never"/>
  <disable_collisions link1="left_link_2" link2="right_link_2" reason="Never"/>

  <xacro:if value="${grip == 'robotiq_2f85'}">
    <!-- Left gripper collision avoidance -->
    <disable_collisions link1="left_robotiq_85_base_link" link2="left_link_6" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_base_link" link2="left_robotiq_85_left_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_base_link" link2="left_robotiq_85_right_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_left_knuckle_link" link2="left_robotiq_85_left_finger_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_right_knuckle_link" link2="left_robotiq_85_right_finger_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_left_finger_link" link2="left_robotiq_85_left_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_right_finger_link" link2="left_robotiq_85_right_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_left_inner_knuckle_link" link2="left_robotiq_85_left_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_right_inner_knuckle_link" link2="left_robotiq_85_right_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_left_inner_knuckle_link" link2="left_robotiq_85_left_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_right_inner_knuckle_link" link2="left_robotiq_85_right_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_base_link" link2="left_robotiq_85_left_inner_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="left_robotiq_85_base_link" link2="left_robotiq_85_right_inner_knuckle_link" reason="Adjacent"/>

    <!-- Right gripper collision avoidance -->
    <disable_collisions link1="right_robotiq_85_base_link" link2="right_link_6" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_base_link" link2="right_robotiq_85_left_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_base_link" link2="right_robotiq_85_right_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_left_knuckle_link" link2="right_robotiq_85_left_finger_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_right_knuckle_link" link2="right_robotiq_85_right_finger_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_left_finger_link" link2="right_robotiq_85_left_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_right_finger_link" link2="right_robotiq_85_right_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_left_inner_knuckle_link" link2="right_robotiq_85_left_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_right_inner_knuckle_link" link2="right_robotiq_85_right_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_left_inner_knuckle_link" link2="right_robotiq_85_left_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_right_inner_knuckle_link" link2="right_robotiq_85_right_finger_tip_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_base_link" link2="right_robotiq_85_left_inner_knuckle_link" reason="Adjacent"/>
    <disable_collisions link1="right_robotiq_85_base_link" link2="right_robotiq_85_right_inner_knuckle_link" reason="Adjacent"/>
  </xacro:if>
</robot>
